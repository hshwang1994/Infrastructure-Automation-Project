// 기존 프로젝트와 동일하게 ansiblePlaybook plugin 방식을 사용한다.
// 모든 실행 블록에 try/finally 를 적용하여 성공/실패와 무관하게 [END] 마커가 출력된다.

pipeline {
    agent { label "${params.loc}" }

    parameters {
        string(name: 'loc',         defaultValue: '', description: '포털 전달: Agent 위치')
        choice(name: 'target_type', choices: ['linux', 'windows', 'esxi', 'redfish'], description: '포털 전달: 대상 종류')
        text(
            name        : 'inventory_json',
            defaultValue: '''[
  { "bmc_ip": "", "service_ip": "", "hostname": "", "vendor": "" }
]''',
            description : '포털에서 전달하는 타겟 호스트 JSON'
        )
    }

    environment {
        INVENTORY_JSON = "${params.inventory_json}"
        TARGET_TYPE    = "${params.target_type}"
        REPO_ROOT      = "${WORKSPACE}"
    }

    stages {
        // ──────────────────────────────────────────────────────
        // Stage 1: 상태 유도 — 7회
        // ──────────────────────────────────────────────────────
        stage('상태 유도') {
            steps {
                // 1) 상태-정상-변경-스킵 (run 1)
                withEnv(["RUN_ID=1"]) {
                    echo '[START] stage=상태유도 playbook=상태-정상-변경-스킵 run_id=1'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/status-ok-changed-skipped.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=상태유도 playbook=상태-정상-변경-스킵 run_id=1'
                        }
                    }
                }

                // 2) 상태-실패-복구-무시 (run 1)
                withEnv(["RUN_ID=1"]) {
                    echo '[START] stage=상태유도 playbook=상태-실패-복구-무시 run_id=1'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/status-fail-rescue-ignore.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=상태유도 playbook=상태-실패-복구-무시 run_id=1'
                        }
                    }
                }

                // 3) 상태-혼합 (run 1)
                withEnv(["RUN_ID=1"]) {
                    echo '[START] stage=상태유도 playbook=상태-혼합 run_id=1'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/status-mixed.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=상태유도 playbook=상태-혼합 run_id=1'
                        }
                    }
                }

                // 4) 상태-정상-변경-스킵 (run 2)
                withEnv(["RUN_ID=2"]) {
                    echo '[START] stage=상태유도 playbook=상태-정상-변경-스킵 run_id=2'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/status-ok-changed-skipped.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=상태유도 playbook=상태-정상-변경-스킵 run_id=2'
                        }
                    }
                }

                // 5) 상태-실패-복구-무시 (run 2)
                withEnv(["RUN_ID=2"]) {
                    echo '[START] stage=상태유도 playbook=상태-실패-복구-무시 run_id=2'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/status-fail-rescue-ignore.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=상태유도 playbook=상태-실패-복구-무시 run_id=2'
                        }
                    }
                }

                // 6) 상태-혼합 (run 2)
                withEnv(["RUN_ID=2"]) {
                    echo '[START] stage=상태유도 playbook=상태-혼합 run_id=2'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/status-mixed.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=상태유도 playbook=상태-혼합 run_id=2'
                        }
                    }
                }

                // 7) 호스트-조건분기 (run 1)
                withEnv(["RUN_ID=1"]) {
                    echo '[START] stage=상태유도 playbook=호스트-조건분기 run_id=1'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/host-condition.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=상태유도 playbook=호스트-조건분기 run_id=1'
                        }
                    }
                }
            }
        }

        // ──────────────────────────────────────────────────────
        // Stage 2: 수집 반복 — 6회
        // ──────────────────────────────────────────────────────
        stage('수집 반복') {
            steps {
                // 1) 메모리-수집 (run 1)
                withEnv(["RUN_ID=1"]) {
                    echo '[START] stage=수집반복 playbook=메모리-수집 run_id=1'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/memory-info.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=수집반복 playbook=메모리-수집 run_id=1'
                        }
                    }
                }

                // 2) 메모리-수집 (run 2)
                withEnv(["RUN_ID=2"]) {
                    echo '[START] stage=수집반복 playbook=메모리-수집 run_id=2'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/memory-info.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=수집반복 playbook=메모리-수집 run_id=2'
                        }
                    }
                }

                // 3) 네트워크-수집 (run 1)
                withEnv(["RUN_ID=1"]) {
                    echo '[START] stage=수집반복 playbook=네트워크-수집 run_id=1'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/network-info.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=수집반복 playbook=네트워크-수집 run_id=1'
                        }
                    }
                }

                // 4) 네트워크-수집 (run 2)
                withEnv(["RUN_ID=2"]) {
                    echo '[START] stage=수집반복 playbook=네트워크-수집 run_id=2'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/network-info.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=수집반복 playbook=네트워크-수집 run_id=2'
                        }
                    }
                }

                // 5) 호스트-조건분기 (run 2)
                withEnv(["RUN_ID=2"]) {
                    echo '[START] stage=수집반복 playbook=호스트-조건분기 run_id=2'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/host-condition.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=수집반복 playbook=호스트-조건분기 run_id=2'
                        }
                    }
                }

                // 6) 상태-혼합 (run 3)
                withEnv(["RUN_ID=3"]) {
                    echo '[START] stage=수집반복 playbook=상태-혼합 run_id=3'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/status-mixed.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=수집반복 playbook=상태-혼합 run_id=3'
                        }
                    }
                }
            }
        }

        // ──────────────────────────────────────────────────────
        // Stage 3: 최종 검증 — 7회
        // ──────────────────────────────────────────────────────
        stage('최종 검증') {
            steps {
                // 1) 호스트-조건분기 (run 3)
                withEnv(["RUN_ID=3"]) {
                    echo '[START] stage=최종검증 playbook=호스트-조건분기 run_id=3'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/host-condition.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=최종검증 playbook=호스트-조건분기 run_id=3'
                        }
                    }
                }

                // 2) 메모리-수집 (run 3)
                withEnv(["RUN_ID=3"]) {
                    echo '[START] stage=최종검증 playbook=메모리-수집 run_id=3'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/memory-info.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=최종검증 playbook=메모리-수집 run_id=3'
                        }
                    }
                }

                // 3) 네트워크-수집 (run 3)
                withEnv(["RUN_ID=3"]) {
                    echo '[START] stage=최종검증 playbook=네트워크-수집 run_id=3'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/network-info.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=최종검증 playbook=네트워크-수집 run_id=3'
                        }
                    }
                }

                // 4) 상태-정상-변경-스킵 (run 3)
                withEnv(["RUN_ID=3"]) {
                    echo '[START] stage=최종검증 playbook=상태-정상-변경-스킵 run_id=3'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/status-ok-changed-skipped.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=최종검증 playbook=상태-정상-변경-스킵 run_id=3'
                        }
                    }
                }

                // 5) 상태-실패-복구-무시 (run 3)
                withEnv(["RUN_ID=3"]) {
                    echo '[START] stage=최종검증 playbook=상태-실패-복구-무시 run_id=3'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/status-fail-rescue-ignore.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=최종검증 playbook=상태-실패-복구-무시 run_id=3'
                        }
                    }
                }

                // 6) 상태-혼합 (run 4)
                withEnv(["RUN_ID=4"]) {
                    echo '[START] stage=최종검증 playbook=상태-혼합 run_id=4'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/status-mixed.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=최종검증 playbook=상태-혼합 run_id=4'
                        }
                    }
                }

                // 7) 강제-실패 (run 1) — 의도적 rc!=0, 마지막 배치
                withEnv(["RUN_ID=1"]) {
                    echo '[START] stage=최종검증 playbook=강제-실패 run_id=1'
                    script {
                        try {
                            ansiblePlaybook(
                                installation: 'ansible',
                                playbook  : "${WORKSPACE}/playbooks/day2/log-parse-sample/windows/force-fail.yml",
                                inventory : "${WORKSPACE}/inventory/my_inventory.sh",
                                colorized : true
                            )
                        } finally {
                            echo '[END] stage=최종검증 playbook=강제-실패 run_id=1'
                        }
                    }
                }
            }
        }
    }
}
