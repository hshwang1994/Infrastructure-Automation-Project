pipeline {
    agent { label "${params.loc}" }

    parameters {
        string(name: 'loc',         defaultValue: '', description: '포털 전달: Agent 위치')
        choice(name: 'target_type', choices: ['linux', 'windows', 'esxi', 'redfish'], description: '포털 전달: 대상 종류')
        text(
            name        : 'inventory_json',
            defaultValue: '''[
  { "bmc_ip": "", "service_ip": "", "hostname": "", "vendor": "" }
]''',
            description : '포털에서 전달하는 타겟 호스트 JSON'
        )
    }

    environment {
        INVENTORY_JSON = "${params.inventory_json}"
        TARGET_TYPE    = "${params.target_type}"
        REPO_ROOT      = "${WORKSPACE}"
    }

    stages {
        stage('Multi Gather') {
            steps {
                ansiblePlaybook(
                    installation: 'ansible',
                    playbook    : "${WORKSPACE}/playbooks/day2/single-stage-multi-playbook/linux/network-check.yml",
                    colorized   : true
                )
                ansiblePlaybook(
                    installation: 'ansible',
                    playbook    : "${WORKSPACE}/playbooks/day2/single-stage-multi-playbook/linux/resource-check.yml",
                    colorized   : true
                )
            }
        }
    }
}
