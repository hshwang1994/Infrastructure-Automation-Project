// 확장 필드 전달 테스트
// 기본 4개 필드 외에 포털이 추가로 보내는 필드가 hostvars 에 정상 전달되는지 검증한다.

pipeline {
    agent { label "${params.loc}" }

    parameters {
        string(name: 'loc',         defaultValue: '', description: '포털 전달: Agent 위치')
        choice(name: 'target_type', choices: ['linux', 'windows', 'esxi', 'redfish'], description: '포털 전달: 대상 종류')
        text(
            name        : 'inventory_json',
            defaultValue: '''[
  {
    "bmc_ip": "",
    "service_ip": "",
    "hostname": "",
    "vendor": "",
    "asset_number": "",
    "owner": "",
    "fab": "",
    "location": "",
    "rack_number": ""
  }
]''',
            description : '포털에서 전달하는 타겟 호스트 JSON'
        )
    }

    environment {
        INVENTORY_JSON = "${params.inventory_json}"
        TARGET_TYPE    = "${params.target_type}"
        REPO_ROOT      = "${WORKSPACE}"
    }

    stages {
        stage('확장 필드 검증') {
            steps {
                ansiblePlaybook(
                    installation: 'ansible',
                    playbook    : "${WORKSPACE}/playbooks/day2/extended-fields-test/linux/site.yml",
                    colorized   : true
                )
            }
        }
    }
}
