// inventory_json 입력 예시 (원본 Jenkinsfile 의 기본값을 그대로 옮겨둔 값입니다):
// [
//   { "bmc_ip": "10.50.11.231", "username": "admin", "vendor": "hp", "workload_profile": "Virtualization-MaxPerformance", "acpi_slit": "Disabled", "thermal_shutdown": "Disabled", "fan_fail_policy": "Allow", "daylight_saving_time": "DaylightSavingsTimeDisabled" }
// ]
//
//   workload_profile      옵션 값 : Virtualization-MaxPerformance
//   acpi_slit             옵션 값 : Enabled, Disabled
//   thermal_shutdown      옵션 값 : Enabled, Disabled
//   fan_fail_policy       옵션 값 : Allow, Shutdown
//   daylight_saving_time  옵션 값 : DaylightSavingsTimeDisabled, DaylightSavingsTimeEnabled
pipeline {
    agent { label "${params.loc}" }

    parameters {
        string(name: 'loc', defaultValue: 'ansible', trim: true)
        choice(name: 'target_type', choices: ['redfish'])
        text(name: 'inventory_json', defaultValue: '''[
  { "bmc_ip": "", "username": "", "vendor": "", "workload_profile": "", "acpi_slit": "", "thermal_shutdown": "", "fan_fail_policy": "", "daylight_saving_time": "" }
]''')
    }

    environment {
        INVENTORY_JSON     = "${params.inventory_json}"
        TARGET_TYPE        = "${params.target_type}"
        ANSIBLE_ROLES_PATH = "${WORKSPACE}/playbooks/day1/ansible/roles"
    }

    stages {

        stage('parse_inventory_json') {
            steps {
                script {
                    if (params.target_type != 'redfish') {
                        error("target_type must be 'redfish'")
                    }
                    def inv = readJSON text: params.inventory_json
                    if (!(inv instanceof List) || inv.isEmpty()) {
                        error("inventory_json must be a non-empty JSON array")
                    }
                    if (inv.size() > 1) {
                        echo "WARN: ${inv.size()} hosts; single-host model — only inv[0] is used"
                    }
                }
            }
        }

        stage('stage01_checkParameters') {
            steps {
                runStage('stage01_checkParameters.yml')
            }
        }

        stage('stage02_maxperfSettings') {
            steps {
                runStage('stage02_maxperfSettings.yml')
            }
        }

    }

    post {
        always {
            cleanWs()
        }
    }
}

def runStage(String stageFile) {
    ansiblePlaybook(
        installation     : 'ansible',
        playbook         : "${WORKSPACE}/playbooks/day1/ansible/playbooks/hpBios/${stageFile}",
        vaultCredentialsId: 'ansible-vault-pass',
        colorized        : true,
        extras           : '-v'
    )
}
